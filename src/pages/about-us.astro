---
import '../index.css';
const pageTitle = 'About Us';
---
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/png" href="/favicon-96x96.png" sizes="96x96" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="shortcut icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <meta name="apple-mobile-web-app-title" content="json" />
    <link rel="manifest" href="/site.webmanifest" />
    <title>{pageTitle} | JSON Compare Online</title>
    <meta name="description" content="Learn about JSON Compare Online, the free JSON comparison tool built for developers, QA teams, and analysts." />
    <meta name="keywords" content="json compare, json compare online, compare json, compare two json files, json diff, json comparison tool, compare json objects, online json compare" />
    <link rel="canonical" href="https://comparejsononline.com/about-us" />
    <meta name="robots" content="index, follow" />
    <meta property="og:type" content="website" />
    <meta property="og:title" content="JSON Compare Online - Free JSON Diff & Compare Tool" />
    <meta property="og:description" content="Compare JSON files instantly with our free online JSON Compare tool. Find differences, validate JSON, and compare JSON objects with ease." />
    <meta property="og:url" content="https://comparejsononline.com/about-us" />
    <meta property="og:image" content="https://comparejsononline.com/og-image.png" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="JSON Compare Online - Free JSON Diff & Compare Tool" />
    <meta name="twitter:description" content="Free online JSON comparison tool to compare JSON files and objects with highlighted differences." />
    <meta name="twitter:image" content="https://comparejsononline.com/og-image.png" />
    <script is:inline>
      (() => {
        const stored = localStorage.getItem('theme');
        const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
        if (stored === 'dark' || (!stored && prefersDark)) {
          document.documentElement.classList.add('dark');
        }
      })();
    </script>
  </head>
  <body class="bg-gray-50 text-gray-900 dark:bg-gray-950 dark:text-gray-100">
    <main class="min-h-screen mx-auto max-w-5xl px-4 py-6 sm:px-6 font-sans transition-colors duration-300">
      <a href="/" class="text-sm font-medium text-blue-600 hover:text-blue-800 dark:text-blue-400">← Back to Home</a>
      <h1 class="mt-4 text-3xl font-bold tracking-tight text-gray-900 dark:text-gray-100">About Us</h1>
      <p class="mt-4 text-gray-700 dark:text-gray-300">
        JSON Compare Online delivers a reliable json comparison online experience for modern development workflows. Our mission is to simplify JSON diff checking and help teams identify actual differences fast.
      </p>
      <section class="mt-8 rounded-3xl border border-gray-200 bg-white p-6 shadow-sm dark:border-gray-800 dark:bg-gray-900">
        <h2 class="text-2xl font-semibold text-gray-900 dark:text-gray-100">Our Mission</h2>
        <p class="mt-3 text-gray-700 dark:text-gray-300">
          We aim to provide a free JSON compare tool that is accessible, accurate, and easy to use. Whether you are comparing two JSON files or deep nested objects, this tool is built to support real development needs.
        </p>
      </section>
      <section class="mt-8 rounded-3xl border border-gray-200 bg-white p-6 shadow-sm dark:border-gray-800 dark:bg-gray-900">
        <h2 class="text-2xl font-semibold text-gray-900 dark:text-gray-100">Why We Built It</h2>
        <p class="mt-3 text-gray-700 dark:text-gray-300">
          JSON development often requires quick validation and comparison. Our online json comparison tool removes friction by letting users compare json objects online directly in the browser without installs.
        </p>
      </section>
    </main>
  </body>
</html>
