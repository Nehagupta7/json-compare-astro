---
import '../index.css';
const pageTitle = 'Contact Us';
---
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/png" href="/favicon-96x96.png" sizes="96x96" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="shortcut icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <meta name="apple-mobile-web-app-title" content="json" />
    <link rel="manifest" href="/site.webmanifest" />
    <title>{pageTitle} | JSON Compare Online</title>
    <meta name="description" content="Contact JSON Compare Online for feedback, support, or questions about the free online JSON comparison tool." />
    <meta name="keywords" content="json compare, json compare online, compare json, compare two json files, json diff, json comparison tool, compare json objects, online json compare" />
    <link rel="canonical" href="https://comparejsononline.com/contact-us" />
    <meta name="robots" content="index, follow" />
    <meta property="og:type" content="website" />
    <meta property="og:title" content="JSON Compare Online - Free JSON Diff & Compare Tool" />
    <meta property="og:description" content="Compare JSON files instantly with our free online JSON Compare tool. Find differences, validate JSON, and compare JSON objects with ease." />
    <meta property="og:url" content="https://comparejsononline.com/contact-us" />
    <meta property="og:image" content="https://comparejsononline.com/og-image.png" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="JSON Compare Online - Free JSON Diff & Compare Tool" />
    <meta name="twitter:description" content="Free online JSON comparison tool to compare JSON files and objects with highlighted differences." />
    <meta name="twitter:image" content="https://comparejsononline.com/og-image.png" />
    <script is:inline>
      (() => {
        const stored = localStorage.getItem('theme');
        const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
        if (stored === 'dark' || (!stored && prefersDark)) {
          document.documentElement.classList.add('dark');
        }
      })();
    </script>
  </head>
  <body class="bg-gray-50 text-gray-900 dark:bg-gray-950 dark:text-gray-100">
    <main class="min-h-screen mx-auto max-w-5xl px-4 py-6 sm:px-6 font-sans transition-colors duration-300">
      <a href="/" class="text-sm font-medium text-blue-600 hover:text-blue-800 dark:text-blue-400">← Back to Home</a>
      <h1 class="mt-4 text-3xl font-bold tracking-tight text-gray-900 dark:text-gray-100">Contact Us</h1>
      <p class="mt-4 text-gray-700 dark:text-gray-300">
        Have a question about JSON Compare Online or want to share feedback? Reach out to us and we will do our best to respond quickly.
      </p>
      <section class="mt-8 rounded-3xl border border-gray-200 bg-white p-6 shadow-sm dark:border-gray-800 dark:bg-gray-900">
        <h2 class="text-2xl font-semibold text-gray-900 dark:text-gray-100">Get in Touch</h2>
        <p class="mt-3 text-gray-700 dark:text-gray-300">
          Send feedback about the JSON compare tool, report issues, or suggest improvements. You can contact us by email at <a href="mailto:support@comparejsononline.com" class="font-medium text-blue-600 hover:text-blue-800 dark:text-blue-400">support@comparejsononline.com</a>.
        </p>
      </section>
      <section class="mt-8 rounded-3xl border border-gray-200 bg-white p-6 shadow-sm dark:border-gray-800 dark:bg-gray-900">
        <h2 class="text-2xl font-semibold text-gray-900 dark:text-gray-100">Feedback Focus</h2>
        <p class="mt-3 text-gray-700 dark:text-gray-300">
          Your feedback helps improve the json diff checker, the user experience, and the support for nested JSON objects. We welcome all suggestions that make the tool more useful.
        </p>
      </section>
    </main>
  </body>
</html>
