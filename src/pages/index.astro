            Learn what JSON is, how JSON files work, and how to compare JSON online with our free diff tool.
          </p>
          <div class="mt-6 space-y-5 text-gray-700 dark:text-gray-300">
            {faqs.map(({ question, answer }) => (
              <article>
                <h3 class="text-lg font-semibold text-gray-900 dark:text-gray-100">{question}</h3>
                <p class="mt-2">{answer}</p>
              </article>
            ))}
          </div>
        </section>

        <section class="mb-8 rounded-3xl border border-blue-300 bg-blue-50 p-6 shadow-sm dark:border-blue-700 dark:bg-blue-950">
          <h2 class="text-2xl font-semibold text-blue-900 dark:text-blue-200">Start comparing JSON online now</h2>
          <p class="mt-4 text-gray-700 dark:text-gray-300">Ready to use the most reliable json compare online tool? Paste your JSON A and JSON B, click Compare, and see all differences clearly. It’s the fastest way to compare JSON objects online and validate your data.</p>
          <div class="mt-6">
            <a href="#jsonA" class="inline-flex rounded-full bg-blue-600 px-5 py-3 text-sm font-semibold text-white shadow-sm hover:bg-blue-700 dark:bg-blue-500 dark:hover:bg-blue-400">Start Comparing JSON</a>
          </div>
        </section>
       
      </div>
    </main>

    <footer class="border-t border-gray-200 bg-white py-6 dark:border-gray-800 dark:bg-gray-950">
      <div class="mx-auto flex max-w-5xl flex-wrap items-center justify-between gap-3 px-4 text-sm text-gray-600 dark:text-gray-400">
        <p>© 2026 JSON Compare Online</p>
        <div class="flex flex-wrap gap-3">
          <a href="/about-us" class="hover:text-gray-900 dark:hover:text-white">About Us</a>
          <a href="/contact-us" class="hover:text-gray-900 dark:hover:text-white">Contact Us</a>
          <a href="/privacy-policy" class="hover:text-gray-900 dark:hover:text-white">Privacy Policy</a>
          <a href="/terms-and-conditions" class="hover:text-gray-900 dark:hover:text-white">Terms &amp; Conditions</a>
        </div>
      </div>
    </footer>

    <script>
      const API_BASE = 'https://api-json-compare-backend.onrender.com/json';
      const SAMPLE_A = {
        id: 158,
        name: 'Plan logs test',
        product_count: 2,
        status: 'draft',
        price: 12,
        cycle: 'month',
        visibility: 'public',
        product: {
          code: 'LGA10',
          default_price: 14.99,
          description: 'Legacy plan A',
          category: null,
          created_at: '2026-04-29T06:03:00Z',
        },
        regions: [
          { id: 1, name: 'US', active: true },
          { id: 2, name: 'EU', active: false },
        ],
      };
      const SAMPLE_B = {
        id: 158,
        name: 'Plan logs test',
        product_count: 3,
        status: 'active',
        price: 15,
        cycle: 'month',
        visibility: 'private',
        product: {
          code: 'LGA10',
          default_price: 14.99,
          description: 'Legacy plan A - updated',
          category: 'premium',
          created_at: '2026-04-29T06:03:00Z',
        },
        regions: [
          { id: 1, name: 'US', active: true },
          { id: 2, name: 'EU', active: true },
        ],
      };

      type JsonPrimitive = null | boolean | number | string;
      type JsonValue = JsonPrimitive | { [key: string]: JsonValue } | JsonValue[];
      type MaybeJson = JsonValue | null | undefined;

      interface AppState {
        dataA: MaybeJson;
        dataB: MaybeJson;
        mode: 'diff' | 'card';
        expanded: Set<string>;
        allPaths: string[];
      }

      const state: AppState = {
        dataA: null,
        dataB: null,
        mode: 'diff',
        expanded: new Set(),
        allPaths: [],
      };

      const $ = (selector: string): HTMLElement | null => document.querySelector(selector);
      const els = {
        jsonA: document.querySelector('#jsonA') as HTMLTextAreaElement,
        jsonB: document.querySelector('#jsonB') as HTMLTextAreaElement,
        errA: document.querySelector('#errA') as HTMLElement,
        errB: document.querySelector('#errB') as HTMLElement,
        toggleInputs: document.querySelector('#toggleInputs') as HTMLButtonElement,
        inputSection: document.querySelector('#inputSection') as HTMLElement,
        diffMode: document.querySelector('#diffMode') as HTMLButtonElement,
        cardMode: document.querySelector('#cardMode') as HTMLButtonElement,
        themeToggle: document.querySelector('#themeToggle') as HTMLButtonElement,
        themeIcon: document.querySelector('#themeIcon') as HTMLElement,
        menuToggle: document.querySelector('#menuToggle') as HTMLButtonElement,
        menuClose: document.querySelector('#menuClose') as HTMLElement,
        mobileMenu: document.querySelector('#mobileMenu') as HTMLElement,
        mainNav: document.querySelector('#mainNav') as HTMLElement,
        loadSample: document.querySelector('#loadSample') as HTMLButtonElement,
        compare: document.querySelector('#compare') as HTMLButtonElement,
        swap: document.querySelector('#swap') as HTMLButtonElement,
        clear: document.querySelector('#clear') as HTMLButtonElement,
        share: document.querySelector('#share') as HTMLButtonElement,
        newSession: document.querySelector('#newSession') as HTMLButtonElement,
        shareError: document.querySelector('#shareError') as HTMLElement,
        shareUrl: document.querySelector('#shareUrl') as HTMLElement,
        summary: document.querySelector('#summary') as HTMLElement,
        changeBadge: document.querySelector('#changeBadge') as HTMLElement,
        expandAll: document.querySelector('#expandAll') as HTMLButtonElement,
        collapseAll: document.querySelector('#collapseAll') as HTMLButtonElement,
        output: document.querySelector('#output') as HTMLElement,
      };

      let deepEqualCache = new WeakMap<object, WeakMap<object, boolean>>();

      const deepEqual = (function () {
        function isPrimitiveValue(x: unknown) {
          return x === null || x === undefined || typeof x !== 'object';
        }

        function eq(a: MaybeJson, b: MaybeJson, seen: WeakMap<object, WeakSet<object>>): boolean {
          if (a === b) return true;
          if (isPrimitiveValue(a) || isPrimitiveValue(b)) return a === b;

          if (Array.isArray(a) || Array.isArray(b)) {
            if (!Array.isArray(a) || !Array.isArray(b)) return false;
            if (a.length !== b.length) return false;
            for (let i = 0; i < a.length; i += 1) {
              if (!eq(a[i] as JsonValue, b[i] as JsonValue, seen)) return false;
            }
            return true;
          }

            // both are non-array objects
            const aObj = a as Record<string, JsonValue>;
            const bObj = b as Record<string, JsonValue>;

            // check result cache for previously computed equality
            let outer = deepEqualCache.get(aObj as object);
            if (outer) {
              const cached = outer.get(bObj as object);
              if (cached !== undefined) return cached;
            } else {
              outer = new WeakMap<object, boolean>();
              deepEqualCache.set(aObj as object, outer);
            }

            let mapped = seen.get(aObj as object);
            if (mapped && mapped.has(bObj as object)) return true;
            if (!mapped) {
              mapped = new WeakSet<object>();
              seen.set(aObj as object, mapped);
            }
            mapped.add(bObj as object);

            const aKeys = Object.keys(aObj);
            const bKeys = Object.keys(bObj);
            if (aKeys.length !== bKeys.length) {
              outer.set(bObj as object, false);
              return false;
            }
            for (let i = 0; i < aKeys.length; i += 1) {
              const key = aKeys[i];
              if (!Object.prototype.hasOwnProperty.call(bObj, key)) {
                outer.set(bObj as object, false);
                return false;
              }
              if (!eq(aObj[key], bObj[key], seen)) {
                outer.set(bObj as object, false);
                return false;
              }
            }
            outer.set(bObj as object, true);
            return true;
        }

        return (a: MaybeJson, b: MaybeJson): boolean => eq(a, b, deepEqualCacheWrapper());
      })();

      function deepEqualCacheWrapper() {
        // provide the current cache for this comparison run; if empty, create a new seen map
        return new WeakMap<object, WeakSet<object>>();
      }
      const arrToObj = (arr: JsonValue[]): Record<string, JsonValue> =>
        arr.reduce<Record<string, JsonValue>>((obj, value, index) => {
          obj[String(index)] = value;
          return obj;
        }, {});
      const titleCase = (key: string): string => key.replace(/_/g, ' ').replace(/\b\w/g, (char) => char.toUpperCase());
      const isObject = (value: MaybeJson): value is Record<string, JsonValue> =>
        value !== null && value !== undefined && !Array.isArray(value) && typeof value === 'object';

      function escapeHtml(value: string | number | boolean | null | undefined): string {
        return String(value)
          .replaceAll('&', '&amp;')
          .replaceAll('<', '&lt;')
          .replaceAll('>', '&gt;')
          .replaceAll('"', '&quot;')
          .replaceAll("'", '&#039;');
      }

      function primitive(value: JsonValue | undefined): string {
        if (value === null || value === undefined) return '<span class="text-gray-400">-</span>';
        if (typeof value === 'boolean') {
          const color = value ? 'text-green-600' : 'text-red-600';
          return `<span class="${color}">${String(value)}</span>`;
        }
        if (typeof value === 'number') {
          return `<span>${value}</span>`;
        }
        if (typeof value === 'string') {
          return `<span>${escapeHtml(value)}</span>`;
        }
        return `<span>${escapeHtml(JSON.stringify(value))}</span>`;
      }

      function getChangedKeys(
        before: { [key: string]: JsonValue } = {},
        after: { [key: string]: JsonValue } = {},
      ): Set<string> {
        const keys = new Set([...Object.keys(before), ...Object.keys(after)]);
        return [...keys].reduce<Set<string>>((changed, key) => {
          if (!deepEqual(before[key], after[key])) changed.add(key);
          return changed;
        }, new Set());
      }

      function countChanges(before: MaybeJson, after: MaybeJson): number {
        if (deepEqual(before, after)) return 0;
        if (Array.isArray(before) || Array.isArray(after)) {
          const leftArray = Array.isArray(before) ? before : [];
          const rightArray = Array.isArray(after) ? after : [];
          let count = 0;
          const length = Math.max(leftArray.length, rightArray.length);
          for (let index = 0; index < length; index += 1) {
            const leftItem = leftArray[index];
            const rightItem = rightArray[index];
            if (isObject(leftItem) && isObject(rightItem)) {
              count += countChanges(leftItem, rightItem);
            } else if (!deepEqual(leftItem, rightItem)) {
              count += 1;
            }
          }
          return count;
        }

        if (isObject(before) && isObject(after)) {
          let count = 0;
          const keys = new Set([...Object.keys(before), ...Object.keys(after)]);
          keys.forEach((key) => {
            const a = before[key];
            const b = after[key];
            if (deepEqual(a, b)) return;
            if (Array.isArray(a) || Array.isArray(b) || (isObject(a) && isObject(b))) {
              count += countChanges(a, b);
            } else {
              count += 1;
            }
          });
          return count;
        }

        return 1;
      }

      function hasChanges(a: MaybeJson, b: MaybeJson): boolean {
        return countChanges(a, b) > 0;
      }

      function collectChangedPaths(obj: MaybeJson, other: MaybeJson, path: string, acc: Set<string>): void {
        if (!isObject(obj)) return;
        const otherObj = isObject(other) ? other : {};
        Object.keys(obj).forEach((key) => {
          const value = obj[key];
          const otherValue = otherObj[key];
          const nodePath = `${path}.${key}`;
          if (Array.isArray(value)) {
            if (hasChanges(arrToObj(value), arrToObj(Array.isArray(otherValue) ? otherValue : []))) {
              acc.add(nodePath);
              value.forEach((item, index) => {
                if (isObject(item)) {
                  const otherItem = Array.isArray(otherValue) ? otherValue[index] : null;
                  if (hasChanges(item, otherItem)) {
                    const itemPath = `${nodePath}[${index}]`;
                    acc.add(itemPath);
                    collectChangedPaths(item, otherItem, itemPath, acc);
                  }
                }
              });
            }
          } else if (isObject(value) && hasChanges(value, otherValue)) {
            acc.add(nodePath);
            collectChangedPaths(value, otherValue, nodePath, acc);
          }
        });
      }

      function collectAllPaths(obj: MaybeJson, other: MaybeJson, path: string, acc: Set<string>): void {
        if (!isObject(obj)) return;
        const otherObj = isObject(other) ? other : {};
        Object.keys(obj).forEach((key) => {
          const value = obj[key];
          const otherValue = otherObj[key];
          const nodePath = `${path}.${key}`;
          if (Array.isArray(value)) {
            acc.add(nodePath);
            value.forEach((item, index) => {
              if (isObject(item)) {
                const itemPath = `${nodePath}[${index}]`;
                acc.add(itemPath);
                collectAllPaths(item, Array.isArray(otherValue) ? otherValue[index] : null, itemPath, acc);
              }
            });
          } else if (isObject(value)) {
            acc.add(nodePath);
            collectAllPaths(value, otherValue ?? null, nodePath, acc);
          }
        });
      }

      function chevron(path: string): string {
        const rotation = state.expanded.has(path) ? 'rotate-90' : '';
        return `<svg class="h-3.5 w-3.5 shrink-0 text-gray-400 transition-transform ${rotation}" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 6l6 6-6 6" stroke-linecap="round" stroke-linejoin="round"></path></svg>`;
      }

      function changedPill(label: string | number): string {
        return `<span class="ml-1.5 rounded-full bg-amber-100 px-1.5 py-0.5 text-[10px] text-amber-800 dark:bg-amber-900 dark:text-amber-200">${label}</span>`;
      }

      function diffRows(obj: MaybeJson, counterpart: MaybeJson, depth: number, side: 'a' | 'b', path: string): string {
        if (!isObject(obj)) return '';
        const changedKeys = getChangedKeys(obj, isObject(counterpart) ? counterpart : {});
        return Object.keys(obj)
          .map((key) => {
            const value = obj[key];
            const otherValue = isObject(counterpart) ? counterpart[key] : null;
            const isChanged = changedKeys.has(key);
            const nodePath = `${path}.${key}`;
            const padding = depth * 16 + 14;
            const rowBase = `flex min-h-[22px] items-start gap-0 border-l-2 py-0.5 font-mono text-[12.5px] ${isChanged ? 'border-amber-400 bg-amber-50 dark:bg-amber-950/30' : 'border-transparent'}`;

            if (Array.isArray(value)) {
              const open = state.expanded.has(nodePath);
              const changeCount = countChanges(arrToObj(value), arrToObj(Array.isArray(otherValue) ? otherValue : []));
              const children = open
                ? value
                    .map((item, index) => {
                      const otherItem = Array.isArray(otherValue) ? otherValue[index] : null;
                      const itemPath = `${nodePath}[${index}]`;
                      if (isObject(item)) {
                        const itemOpen = state.expanded.has(itemPath);
                        const itemChanged = hasChanges(item, otherItem);
                        return `<div class="mx-3.5 my-1 overflow-hidden rounded-md border ${itemChanged ? 'border-amber-400' : 'border-gray-200 dark:border-gray-700'}" style="margin-left:${padding + 10}px">
                          <button type="button" data-toggle="${itemPath}" class="flex w-full items-center gap-1 border-b border-gray-200 px-2.5 py-1 text-left text-[11px] text-gray-400 hover:bg-gray-50 dark:border-gray-700 dark:hover:bg-gray-800/50">
                            ${chevron(itemPath)}<span>[${index}]</span>${itemChanged ? changedPill('changed') : ''}
                          </button>
                          ${itemOpen ? diffRows(item, otherItem ?? null, 0, side, itemPath) : ''}
                        </div>`;
                      }
                      const rowChanged = !deepEqual(item, otherItem ?? null);
                      return `<div class="flex min-h-[22px] items-start border-l-2 py-0.5 font-mono text-[12.5px] ${rowChanged ? 'border-amber-400 bg-amber-50 dark:bg-amber-950/30' : 'border-transparent'}" style="padding-left:${padding + 16}px">
                        <span class="mr-1.5 text-gray-500 dark:text-gray-400">[${index}]</span>${primitive(item)}
                      </div>`;
                    })
                    .join('')
                : '';
              return `<div>
                <button type="button" data-toggle="${nodePath}" class="${rowBase} w-full cursor-pointer text-left hover:bg-gray-50 dark:hover:bg-gray-800/50" style="padding-left:${padding}px">
                  ${chevron(nodePath)}<span class="ml-1 mr-1.5 text-gray-500 dark:text-gray-400">${escapeHtml(key)}:</span><span class="text-gray-400">[${value.length}]</span>${changeCount > 0 ? changedPill(`${changeCount} changed`) : ''}
                </button>${children}
              </div>`;
            }

            if (isObject(value)) {
              const open = state.expanded.has(nodePath);
              const changeCount = countChanges(value, otherValue ?? null);
              return `<div>
                <button type="button" data-toggle="${nodePath}" class="${rowBase} w-full cursor-pointer text-left hover:bg-gray-50 dark:hover:bg-gray-800/50" style="padding-left:${padding}px">
                  ${chevron(nodePath)}<span class="ml-1 mr-1.5 text-gray-500 dark:text-gray-400">${escapeHtml(key)}:</span><span class="text-gray-400">{}</span>${changeCount > 0 ? changedPill(`${changeCount} changed`) : ''}
                </button>${open ? diffRows(value, otherValue ?? null, depth + 1, side, nodePath) : ''}
              </div>`;
            }

            const valueClass = side === 'a'
              ? 'bg-red-100 text-red-700 dark:bg-red-950 dark:text-red-300'
              : 'bg-green-100 text-green-700 dark:bg-green-950 dark:text-green-300';
            return `<div class="${rowBase}" style="padding-left:${padding}px">
              <span class="mr-1.5 text-gray-500 dark:text-gray-400">${escapeHtml(key)}:</span>
              ${isChanged ? `<span class="rounded px-1.5 py-0.5 font-medium ${valueClass}">${primitive(value)}</span>` : primitive(value)}
            </div>`;
          })
          .join('');
      }

      function cardView(obj: MaybeJson, counterpart: MaybeJson, depth: number, path: string): string {
        if (!isObject(obj)) return '';
        const changedKeys = getChangedKeys(obj, isObject(counterpart) ? counterpart : {});
        return Object.keys(obj)
          .map((key) => {
            const value = obj[key];
            const otherValue = isObject(counterpart) ? counterpart[key] : null;
            const isChanged = changedKeys.has(key);
            const nodePath = `${path}.${key}`;
            if (Array.isArray(value)) {
              const open = state.expanded.has(nodePath);
              const otherArray = Array.isArray(otherValue) ? otherValue : [];
              const changeCount = countChanges(arrToObj(value), arrToObj(otherArray));
              const children = open
                ? value
                    .map((item, index) => {
                      const otherItem = Array.isArray(otherValue) ? otherValue[index] : null;
                      if (isObject(item)) {
                        const itemPath = `${nodePath}[${index}]`;
                        const itemOpen = state.expanded.has(itemPath);
                        const itemChanged = hasChanges(item, otherItem);
                        return `<div class="my-1.5 rounded-md border p-2.5 ${itemChanged ? 'border-amber-400' : 'border-gray-200 dark:border-gray-700'} bg-gray-50 dark:bg-gray-800/40">
                          <button type="button" data-toggle="${itemPath}" class="flex items-center gap-1 text-left">
                            ${chevron(itemPath)}<span class="text-[11px] font-medium uppercase tracking-wide text-gray-500 dark:text-gray-400">Item ${index}</span>${itemChanged ? changedPill('changed') : ''}
                          </button>
                          ${itemOpen ? cardView(item, otherItem ?? null, depth + 1, itemPath) : ''}
                        </div>`;
                      }
                      const rowChanged = !deepEqual(item, otherItem ?? null);
                      return `<div class="flex justify-between gap-3 border-b border-gray-100 py-1.5 text-[13px] last:border-b-0 dark:border-gray-800 ${rowChanged ? '-mx-2.5 rounded bg-amber-50 px-2.5 dark:bg-amber-950/30' : ''}">
                        <span class="text-xs text-gray-500 dark:text-gray-400">[${index}]</span><span class="max-w-[60%] break-words text-right font-medium">${primitive(item)}</span>
                      </div>`;
                    })
                    .join('')
                : '';
              return `<div class="${depth ? 'mt-2' : 'mt-2.5'}">
                <button type="button" data-toggle="${nodePath}" class="group flex items-center gap-1 text-left">
                  ${chevron(nodePath)}<span class="text-[11px] font-medium uppercase tracking-wide text-gray-500 group-hover:text-gray-900 dark:text-gray-400 dark:group-hover:text-gray-100">${titleCase(escapeHtml(key))} (${value.length})</span>${changeCount > 0 ? changedPill(changeCount) : ''}
                </button>${children}
              </div>`;
            }

            if (isObject(value)) {
              const open = state.expanded.has(nodePath);
              const changeCount = countChanges(value, otherValue ?? null);
              return `<div class="${depth ? 'mt-2' : 'mt-2.5'}">
                <button type="button" data-toggle="${nodePath}" class="group flex items-center gap-1 text-left">
                  ${chevron(nodePath)}<span class="text-[11px] font-medium uppercase tracking-wide text-gray-500 group-hover:text-gray-900 dark:text-gray-400 dark:group-hover:text-gray-100">${titleCase(escapeHtml(key))}</span>${changeCount > 0 ? changedPill(changeCount) : ''}
                </button>
                ${open ? `<div class="mt-1.5 rounded-md border p-2.5 ${changeCount > 0 ? 'border-amber-400' : 'border-gray-200 dark:border-gray-700'} bg-gray-50 dark:bg-gray-800/40">${cardView(value, otherValue ?? null, depth + 1, nodePath)}</div>` : ''}
              </div>`;
            }

            return `<div class="flex justify-between gap-3 border-b border-gray-100 py-1.5 text-[13px] last:border-b-0 dark:border-gray-800 ${isChanged ? '-mx-2.5 rounded bg-amber-50 px-2.5 dark:bg-amber-950/30' : ''}">
              <span class="text-xs text-gray-500 dark:text-gray-400">${titleCase(escapeHtml(key))}</span>
              <span class="max-w-[60%] break-words text-right font-medium">${primitive(value)}</span>
            </div>`;
          })
          .join('');
      }

      function panel(label: string, content: string): string {
        return `<article class="overflow-hidden rounded-lg border border-gray-200 dark:border-gray-700">
          <header class="border-b border-gray-200 bg-gray-50 px-3.5 py-2 text-xs font-medium uppercase tracking-wide text-gray-500 dark:border-gray-700 dark:bg-gray-800/50 dark:text-gray-400">${label}</header>
          <div class="overflow-x-auto bg-white ${state.mode === 'card' ? 'p-3' : ''} dark:bg-gray-900">${content}</div>
        </article>`;
      }

      function setError(element: HTMLElement, message: string): void {
        element.textContent = message;
        element.classList.toggle('hidden', !message);
      }

      function setShareError(message: string): void {
        els.shareError.textContent = message;
        els.shareError.classList.toggle('hidden', !message);
      }

      function setShareUrl(url: string | null): void {
        els.shareUrl.innerHTML = url
          ? `Share link: <a href="${url}" class="text-blue-600 underline dark:text-blue-300" target="_blank" rel="noreferrer">${url}</a>`
          : '';
        els.shareUrl.classList.toggle('hidden', !url);
      }

      function getCurrentShareId(): string | null {
        return new URL(window.location.href).searchParams.get('shareId');
      }

      function updateModeButtons() {
        const active = 'bg-white text-gray-900 shadow-sm font-medium dark:bg-gray-700 dark:text-white';
        const inactive = 'text-gray-500 hover:text-gray-700 dark:text-gray-400 dark:hover:text-gray-200';
        els.diffMode.className = `rounded-md px-3.5 py-1.5 text-sm transition-colors ${state.mode === 'diff' ? active : inactive}`;
        els.cardMode.className = `rounded-md px-3.5 py-1.5 text-sm transition-colors ${state.mode === 'card' ? active : inactive}`;
      }

      function updateThemeIcon() {
        const isDark = document.documentElement.classList.contains('dark');
        els.themeIcon.innerHTML = isDark
          ? '<svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="4"></circle><path stroke-linecap="round" d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41"></path></svg>'
          : '<svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79Z"></path></svg>';
      }

      function setComparedData(dataA: MaybeJson, dataB: MaybeJson): void {
        state.dataA = dataA;
        state.dataB = dataB;
        // reset deepEqual result cache for new comparison
        deepEqualCache = new WeakMap();

        // show quick UI feedback and avoid blocking the main thread
        if (els.output) els.output.innerHTML = '<div class="p-6 text-center text-sm text-gray-500">Comparing...</div>';
        if (els.compare) els.compare.disabled = true;

        // run expensive collection asynchronously so the browser can update UI
        setTimeout(() => {
          try {
            const expanded = new Set<string>();
            collectChangedPaths(dataA, dataB, 'root', expanded);
            state.expanded = expanded;
            const allPaths = new Set<string>();
            collectAllPaths(dataA, dataB, 'root', allPaths);
            collectAllPaths(dataB, dataA, 'root', allPaths);
            state.allPaths = [...allPaths];
            render();
          } catch (err) {
            // eslint-disable-next-line no-console
            console.error('Comparison error', err);
            if (els.output) els.output.innerHTML = '<div class="p-6 text-center text-sm text-red-600">Comparison failed. Check console for details.</div>';
          } finally {
            if (els.compare) els.compare.disabled = false;
          }
        }, 10);
      }

      function render() {
        const hasOutput = state.dataA !== null && state.dataB !== null;
        const currentId = getCurrentShareId();
        const showSaveButton = hasOutput;
        const saveLabel = currentId ? 'Save' : 'Share';

        els.clear.classList.toggle('hidden', !hasOutput);
        els.share.classList.toggle('hidden', !showSaveButton);
        els.share.textContent = saveLabel;
        els.newSession.classList.toggle('hidden', !currentId);
        els.summary.classList.toggle('hidden', !hasOutput);
        els.summary.classList.toggle('flex', hasOutput);
        updateModeButtons();

        if (!hasOutput) {
          els.output.innerHTML = '';
          return;
        }

        const totalChanges = countChanges(state.dataA ?? null, state.dataB ?? null);
        els.changeBadge.textContent = totalChanges > 0
          ? `${totalChanges} key${totalChanges === 1 ? '' : 's'} changed`
          : 'Identical';
        els.changeBadge.className = `rounded-full px-2.5 py-1 text-xs font-medium ${totalChanges > 0 ? 'bg-amber-100 text-amber-800 dark:bg-amber-900 dark:text-amber-200' : 'bg-green-100 text-green-800 dark:bg-green-900 dark:text-green-200'}`;

        const left = state.mode === 'diff'
          ? diffRows(state.dataA, state.dataB, 0, 'a', 'root')
          : cardView(state.dataA, state.dataB, 0, 'root');
        const right = state.mode === 'diff'
          ? diffRows(state.dataB, state.dataA, 0, 'b', 'root')
          : cardView(state.dataB, state.dataA, 0, 'root');
        const labels = state.mode === 'diff' ? ['A', 'B'] : ['A - formatted', 'B - formatted'];
        els.output.innerHTML = `<div class="grid grid-cols-1 gap-2 md:grid-cols-2">${panel(labels[0], left)}${panel(labels[1], right)}</div>`;
      }

      function parseCurrentInputs(): { dataA: JsonValue; dataB: JsonValue } | null {
        setError(els.errA, '');
        setError(els.errB, '');
        setShareError('');

        if (!els.jsonA.value.trim() || !els.jsonB.value.trim()) {
          if (!els.jsonA.value.trim()) setError(els.errA, 'Paste a JSON object to compare');
          if (!els.jsonB.value.trim()) setError(els.errB, 'Paste a JSON object to compare');
          return null;
        }

        let dataA: JsonValue;
        let dataB: JsonValue;
        try {
          dataA = JSON.parse(els.jsonA.value) as JsonValue;
        } catch (error: unknown) {
          const message = error instanceof Error ? error.message : String(error);
          setError(els.errA, `Invalid JSON: ${message}`);
          return null;
        }
        try {
          dataB = JSON.parse(els.jsonB.value) as JsonValue;
        } catch (error: unknown) {
          const message = error instanceof Error ? error.message : String(error);
          setError(els.errB, `Invalid JSON: ${message}`);
          return null;
        }
        return { dataA, dataB };
      }

      function currentInputsValid() {
        if (!els.jsonA.value.trim() || !els.jsonB.value.trim()) return false;
        try {
          JSON.parse(els.jsonA.value);
          JSON.parse(els.jsonB.value);
          return true;
        } catch {
          return false;
        }
      }

      function runCompare() {
        setShareUrl('');
        const parsed = parseCurrentInputs();
        if (!parsed) return;
        setComparedData(parsed.dataA, parsed.dataB);
        setInputVisibility(false);
      }

      function setInputVisibility(visible: boolean): void {
        if (!els.inputSection || !els.toggleInputs) return;
        els.inputSection.classList.toggle('hidden', !visible);
        els.toggleInputs.textContent = visible ? 'Hide Inputs' : 'Edit Input';
      }

      function clearAll() {
        els.jsonA.value = '';
        els.jsonB.value = '';
        setError(els.errA, '');
        setError(els.errB, '');
        setShareError('');
        setShareUrl('');
        state.dataA = null;
        state.dataB = null;
        state.expanded = new Set();
        state.allPaths = [];
        render();
        setInputVisibility(true);
      }

      function createNewSession() {
        const newUrl = window.location.pathname;
        window.history.replaceState(null, '', newUrl);
        clearAll();
      }

      async function loadSharedComparison(): Promise<void> {
        const id = getCurrentShareId();
        if (!id) return;
        els.share.disabled = true;
        setShareError('');
        try {
          const response = await fetch(`${API_BASE}/${id}`);
          if (!response.ok) throw new Error(`Could not load shared comparison (${response.status})`);
          const data = await response.json();
          els.jsonA.value = JSON.stringify(data.json1, null, 2);
          els.jsonB.value = JSON.stringify(data.json2, null, 2);
          setComparedData(data.json1 as JsonValue, data.json2 as JsonValue);
          setShareUrl(window.location.href);
        } catch (error: unknown) {
          const message = error instanceof Error ? error.message : String(error);
          setShareError(message || 'Failed to load shared comparison.');
        } finally {
          els.share.disabled = false;
        }
      }

      async function shareComparison(): Promise<void> {
        const parsed = parseCurrentInputs();
        if (!parsed) return;

        els.share.disabled = true;
        els.share.textContent = 'Saving...';
        try {
          setComparedData(parsed.dataA, parsed.dataB);
          const currentShareId = getCurrentShareId();
          const endpoint = currentShareId ? `${API_BASE}/${currentShareId}` : API_BASE;
          const response = await fetch(endpoint, {
            method: currentShareId ? 'PUT' : 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ json1: parsed.dataA, json2: parsed.dataB, comparison_result: null }),
          });
          if (!response.ok) {
            const action = currentShareId ? 'update' : 'share';
            throw new Error(`Failed to ${action} comparison (${response.status})`);
          }
          const data = await response.json();
          const shareLink = `${window.location.origin}${window.location.pathname}?shareId=${data.id}`;
          setShareUrl(shareLink);
          window.history.replaceState(null, '', shareLink);
        } catch (error: unknown) {
          const message = error instanceof Error ? error.message : String(error);
          setShareError(message || 'Unable to create share link.');
        } finally {
          els.share.disabled = false;
          els.share.textContent = 'Save';
        }
      }

      els.diffMode.addEventListener('click', () => {
        state.mode = 'diff';
        render();
      });
      els.cardMode.addEventListener('click', () => {
        state.mode = 'card';
        render();
      });
      els.themeToggle.addEventListener('click', () => {
        const nextIsDark = !document.documentElement.classList.contains('dark');
        document.documentElement.classList.toggle('dark', nextIsDark);
        localStorage.setItem('theme', nextIsDark ? 'dark' : 'light');
        updateThemeIcon();
      });
      const hideMobileMenu = () => {
        if (!els.mobileMenu || !els.menuToggle) return;
        els.mobileMenu.classList.add('hidden');
        els.menuToggle.setAttribute('aria-expanded', 'false');
      };

      const showMobileMenu = () => {
        if (!els.mobileMenu || !els.menuToggle) return;
        els.mobileMenu.classList.remove('hidden');
        els.menuToggle.setAttribute('aria-expanded', 'true');
      };

      if (els.menuToggle && els.mobileMenu) {
        els.menuToggle.addEventListener('click', () => {
          const expanded = els.menuToggle.getAttribute('aria-expanded') === 'true';
          if (expanded) hideMobileMenu();
          else showMobileMenu();
        });
      }
      if (els.menuClose) {
        els.menuClose.addEventListener('click', hideMobileMenu);
      }
      if (els.mobileMenu) {
        els.mobileMenu.querySelectorAll<HTMLAnchorElement>('a').forEach((link) => {
          link.addEventListener('click', hideMobileMenu);
        });
      }
      els.loadSample.addEventListener('click', () => {
        els.jsonA.value = JSON.stringify(SAMPLE_A, null, 2);
        els.jsonB.value = JSON.stringify(SAMPLE_B, null, 2);
        setError(els.errA, '');
        setError(els.errB, '');
        setComparedData(SAMPLE_A, SAMPLE_B);
      });
      els.compare.addEventListener('click', runCompare);
      els.jsonA.addEventListener('input', render);
      els.jsonB.addEventListener('input', render);
      els.swap.addEventListener('click', () => {
        const rawA = els.jsonA.value;
        els.jsonA.value = els.jsonB.value;
        els.jsonB.value = rawA;
        if (state.dataA || state.dataB) setComparedData(state.dataB ?? null, state.dataA ?? null);
      });
      if (els.toggleInputs && els.inputSection) {
        els.toggleInputs.addEventListener('click', () => {
          const visible = els.inputSection.classList.toggle('hidden') === false;
          els.toggleInputs.textContent = visible ? 'Hide inputs' : 'Show inputs';
        });
      }
      els.clear.addEventListener('click', clearAll);
      els.share.addEventListener('click', shareComparison);
      els.newSession.addEventListener('click', createNewSession);
      els.expandAll.addEventListener('click', () => {
        state.expanded = new Set(state.allPaths);
        render();
      });
      els.collapseAll.addEventListener('click', () => {
        state.expanded = new Set();
        render();
      });
      els.output.addEventListener('click', (event: MouseEvent) => {
        const target = event.target as HTMLElement | null;
        const button = target?.closest('[data-toggle]') as HTMLElement | null;
        if (!button) return;
        const path = button.getAttribute('data-toggle');
        if (!path) return;
        if (state.expanded.has(path)) state.expanded.delete(path);
        else state.expanded.add(path);
        render();
      });

      updateThemeIcon();
      render();
      loadSharedComparison();
    </script>
  </body>
</html>
