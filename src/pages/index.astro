          { id: 2, name: 'EU', active: true },
        ],
      };

      const state = {
        dataA: null,
        dataB: null,
        mode: 'diff',
        expanded: new Set(),
        allPaths: [],
      };

      const $ = (selector) => document.querySelector(selector);
      const els = {
        jsonA: $('#jsonA'),
        jsonB: $('#jsonB'),
        errA: $('#errA'),
        errB: $('#errB'),
        diffMode: $('#diffMode'),
        cardMode: $('#cardMode'),
        themeToggle: $('#themeToggle'),
        themeIcon: $('#themeIcon'),
        loadSample: $('#loadSample'),
        compare: $('#compare'),
        swap: $('#swap'),
        clear: $('#clear'),
        share: $('#share'),
        newSession: $('#newSession'),
        shareError: $('#shareError'),
        shareUrl: $('#shareUrl'),
        summary: $('#summary'),
        changeBadge: $('#changeBadge'),
        expandAll: $('#expandAll'),
        collapseAll: $('#collapseAll'),
        output: $('#output'),
      };

      const deepEqual = (a, b) => JSON.stringify(a) === JSON.stringify(b);
      const arrToObj = (arr) => arr.reduce((obj, value, index) => ({ ...obj, [index]: value }), {});
      const titleCase = (key) => key.replace(/_/g, ' ').replace(/\b\w/g, (char) => char.toUpperCase());
      const isObject = (value) => value && typeof value === 'object';

      function escapeHtml(value) {
        return String(value)
          .replaceAll('&', '&amp;')
          .replaceAll('<', '&lt;')
          .replaceAll('>', '&gt;')
          .replaceAll('"', '&quot;')
          .replaceAll("'", '&#039;');
      }

      function primitive(value) {
        if (value === null || value === undefined) return '<span class="text-gray-400">-</span>';
        if (typeof value === 'boolean') {
          const color = value ? 'text-green-600' : 'text-red-600';
          return `<span class="${color}">${String(value)}</span>`;
        }
        return `<span>${escapeHtml(value)}</span>`;
      }

      function getChangedKeys(before = {}, after = {}) {
        const keys = new Set([...Object.keys(before || {}), ...Object.keys(after || {})]);
        return [...keys].reduce((changed, key) => {
          if (!deepEqual(before?.[key], after?.[key])) changed.add(key);
          return changed;
        }, new Set());
      }

      function countChanges(before = {}, after = {}) {
        let count = 0;
        const left = before || {};
        const right = after || {};
        const keys = new Set([...Object.keys(left), ...Object.keys(right)]);
        keys.forEach((key) => {
          const a = left[key];
          const b = right[key];
          if (deepEqual(a, b)) return;
          if (Array.isArray(a) || Array.isArray(b)) {
            const leftArray = a || [];
            const rightArray = b || [];
            const length = Math.max(leftArray.length, rightArray.length);
            for (let index = 0; index < length; index += 1) {
              const leftItem = leftArray[index];
              const rightItem = rightArray[index];
              if (isObject(leftItem) && isObject(rightItem)) {
                count += countChanges(leftItem, rightItem);
              } else if (!deepEqual(leftItem, rightItem)) {
                count += 1;
              }
            }
          } else if (isObject(a) && isObject(b)) {
            count += countChanges(a, b);
          } else {
            count += 1;
          }
        });
        return count;
      }

      function hasChanges(a, b) {
        return countChanges(a, b) > 0;
      }

      function collectChangedPaths(obj, other, path, acc) {
        if (!isObject(obj)) return;
        Object.keys(obj).forEach((key) => {
          const value = obj[key];
          const otherValue = other?.[key];
          const nodePath = `${path}.${key}`;
          if (Array.isArray(value)) {
            if (hasChanges(arrToObj(value), arrToObj(otherValue || []))) {
              acc.add(nodePath);
              value.forEach((item, index) => {
                if (isObject(item)) {
                  const otherItem = Array.isArray(otherValue) ? otherValue[index] : undefined;
                  if (hasChanges(item, otherItem)) {
                    const itemPath = `${nodePath}[${index}]`;
                    acc.add(itemPath);
                    collectChangedPaths(item, otherItem, itemPath, acc);
                  }
                }
              });
            }
          } else if (isObject(value) && hasChanges(value, otherValue)) {
            acc.add(nodePath);
            collectChangedPaths(value, otherValue, nodePath, acc);
          }
        });
      }

      function collectAllPaths(obj, other, path, acc) {
        if (!isObject(obj)) return;
        Object.keys(obj).forEach((key) => {
          const value = obj[key];
          const otherValue = other?.[key];
          const nodePath = `${path}.${key}`;
          if (Array.isArray(value)) {
            acc.add(nodePath);
            value.forEach((item, index) => {
              if (isObject(item)) {
                const itemPath = `${nodePath}[${index}]`;
                acc.add(itemPath);
                collectAllPaths(item, Array.isArray(otherValue) ? otherValue[index] : undefined, itemPath, acc);
              }
            });
          } else if (isObject(value)) {
            acc.add(nodePath);
            collectAllPaths(value, otherValue, nodePath, acc);
          }
        });
      }

      function chevron(path) {
        const rotation = state.expanded.has(path) ? 'rotate-90' : '';
        return `<svg class="h-3.5 w-3.5 shrink-0 text-gray-400 transition-transform ${rotation}" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 6l6 6-6 6" stroke-linecap="round" stroke-linejoin="round"></path></svg>`;
      }

      function changedPill(label) {
        return `<span class="ml-1.5 rounded-full bg-amber-100 px-1.5 py-0.5 text-[10px] text-amber-800 dark:bg-amber-900 dark:text-amber-200">${label}</span>`;
      }

      function diffRows(obj, counterpart, depth, side, path) {
        if (!isObject(obj)) return '';
        const changedKeys = getChangedKeys(obj, counterpart);
        return Object.keys(obj)
          .map((key) => {
            const value = obj[key];
            const otherValue = counterpart?.[key];
            const isChanged = changedKeys.has(key);
            const nodePath = `${path}.${key}`;
            const padding = depth * 16 + 14;
            const rowBase = `flex min-h-[22px] items-start gap-0 border-l-2 py-0.5 font-mono text-[12.5px] ${isChanged ? 'border-amber-400 bg-amber-50 dark:bg-amber-950/30' : 'border-transparent'}`;

            if (Array.isArray(value)) {
              const open = state.expanded.has(nodePath);
              const changeCount = countChanges(arrToObj(value), arrToObj(otherValue || []));
              const children = open
                ? value
                    .map((item, index) => {
                      const otherItem = Array.isArray(otherValue) ? otherValue[index] : undefined;
                      const itemPath = `${nodePath}[${index}]`;
                      if (isObject(item)) {
                        const itemOpen = state.expanded.has(itemPath);
                        const itemChanged = hasChanges(item, otherItem);
                        return `<div class="mx-3.5 my-1 overflow-hidden rounded-md border ${itemChanged ? 'border-amber-400' : 'border-gray-200 dark:border-gray-700'}" style="margin-left:${padding + 10}px">
                          <button type="button" data-toggle="${itemPath}" class="flex w-full items-center gap-1 border-b border-gray-200 px-2.5 py-1 text-left text-[11px] text-gray-400 hover:bg-gray-50 dark:border-gray-700 dark:hover:bg-gray-800/50">
                            ${chevron(itemPath)}<span>[${index}]</span>${itemChanged ? changedPill('changed') : ''}
                          </button>
                          ${itemOpen ? diffRows(item, otherItem, 0, side, itemPath) : ''}
                        </div>`;
                      }
                      const rowChanged = !deepEqual(item, otherItem);
                      return `<div class="flex min-h-[22px] items-start border-l-2 py-0.5 font-mono text-[12.5px] ${rowChanged ? 'border-amber-400 bg-amber-50 dark:bg-amber-950/30' : 'border-transparent'}" style="padding-left:${padding + 16}px">
                        <span class="mr-1.5 text-gray-500 dark:text-gray-400">[${index}]</span>${primitive(item)}
                      </div>`;
                    })
                    .join('')
                : '';
              return `<div>
                <button type="button" data-toggle="${nodePath}" class="${rowBase} w-full cursor-pointer text-left hover:bg-gray-50 dark:hover:bg-gray-800/50" style="padding-left:${padding}px">
                  ${chevron(nodePath)}<span class="ml-1 mr-1.5 text-gray-500 dark:text-gray-400">${escapeHtml(key)}:</span><span class="text-gray-400">[${value.length}]</span>${changeCount > 0 ? changedPill(`${changeCount} changed`) : ''}
                </button>${children}
              </div>`;
            }

            if (isObject(value)) {
              const open = state.expanded.has(nodePath);
              const changeCount = countChanges(value, otherValue);
              return `<div>
                <button type="button" data-toggle="${nodePath}" class="${rowBase} w-full cursor-pointer text-left hover:bg-gray-50 dark:hover:bg-gray-800/50" style="padding-left:${padding}px">
                  ${chevron(nodePath)}<span class="ml-1 mr-1.5 text-gray-500 dark:text-gray-400">${escapeHtml(key)}:</span><span class="text-gray-400">{}</span>${changeCount > 0 ? changedPill(`${changeCount} changed`) : ''}
                </button>${open ? diffRows(value, otherValue, depth + 1, side, nodePath) : ''}
              </div>`;
            }

            const valueClass = side === 'a'
              ? 'bg-red-100 text-red-700 dark:bg-red-950 dark:text-red-300'
              : 'bg-green-100 text-green-700 dark:bg-green-950 dark:text-green-300';
            return `<div class="${rowBase}" style="padding-left:${padding}px">
              <span class="mr-1.5 text-gray-500 dark:text-gray-400">${escapeHtml(key)}:</span>
              ${isChanged ? `<span class="rounded px-1.5 py-0.5 font-medium ${valueClass}">${primitive(value)}</span>` : primitive(value)}
            </div>`;
          })
          .join('');
      }

      function cardView(obj, counterpart, depth, path) {
        if (!isObject(obj)) return '';
        const changedKeys = getChangedKeys(obj, counterpart);
        return Object.keys(obj)
          .map((key) => {
            const value = obj[key];
            const otherValue = counterpart?.[key];
            const isChanged = changedKeys.has(key);
            const nodePath = `${path}.${key}`;
            if (Array.isArray(value)) {
              const open = state.expanded.has(nodePath);
              const changeCount = countChanges(arrToObj(value), arrToObj(otherValue || []));
              const children = open
                ? value
                    .map((item, index) => {
                      const otherItem = Array.isArray(otherValue) ? otherValue[index] : undefined;
                      if (isObject(item)) {
                        const itemPath = `${nodePath}[${index}]`;
                        const itemOpen = state.expanded.has(itemPath);
                        const itemChanged = hasChanges(item, otherItem);
                        return `<div class="my-1.5 rounded-md border p-2.5 ${itemChanged ? 'border-amber-400' : 'border-gray-200 dark:border-gray-700'} bg-gray-50 dark:bg-gray-800/40">
                          <button type="button" data-toggle="${itemPath}" class="flex items-center gap-1 text-left">
                            ${chevron(itemPath)}<span class="text-[11px] font-medium uppercase tracking-wide text-gray-500 dark:text-gray-400">Item ${index}</span>${itemChanged ? changedPill('changed') : ''}
                          </button>
                          ${itemOpen ? cardView(item, otherItem, depth + 1, itemPath) : ''}
                        </div>`;
                      }
                      const rowChanged = !deepEqual(item, otherItem);
                      return `<div class="flex justify-between gap-3 border-b border-gray-100 py-1.5 text-[13px] last:border-b-0 dark:border-gray-800 ${rowChanged ? '-mx-2.5 rounded bg-amber-50 px-2.5 dark:bg-amber-950/30' : ''}">
                        <span class="text-xs text-gray-500 dark:text-gray-400">[${index}]</span><span class="max-w-[60%] break-words text-right font-medium">${primitive(item)}</span>
                      </div>`;
                    })
                    .join('')
                : '';
              return `<div class="${depth ? 'mt-2' : 'mt-2.5'}">
                <button type="button" data-toggle="${nodePath}" class="group flex items-center gap-1 text-left">
                  ${chevron(nodePath)}<span class="text-[11px] font-medium uppercase tracking-wide text-gray-500 group-hover:text-gray-900 dark:text-gray-400 dark:group-hover:text-gray-100">${titleCase(escapeHtml(key))} (${value.length})</span>${changeCount > 0 ? changedPill(changeCount) : ''}
                </button>${children}
              </div>`;
            }

            if (isObject(value)) {
              const open = state.expanded.has(nodePath);
              const changeCount = countChanges(value, otherValue);
              return `<div class="${depth ? 'mt-2' : 'mt-2.5'}">
                <button type="button" data-toggle="${nodePath}" class="group flex items-center gap-1 text-left">
                  ${chevron(nodePath)}<span class="text-[11px] font-medium uppercase tracking-wide text-gray-500 group-hover:text-gray-900 dark:text-gray-400 dark:group-hover:text-gray-100">${titleCase(escapeHtml(key))}</span>${changeCount > 0 ? changedPill(changeCount) : ''}
                </button>
                ${open ? `<div class="mt-1.5 rounded-md border p-2.5 ${changeCount > 0 ? 'border-amber-400' : 'border-gray-200 dark:border-gray-700'} bg-gray-50 dark:bg-gray-800/40">${cardView(value, otherValue, depth + 1, nodePath)}</div>` : ''}
              </div>`;
            }

            return `<div class="flex justify-between gap-3 border-b border-gray-100 py-1.5 text-[13px] last:border-b-0 dark:border-gray-800 ${isChanged ? '-mx-2.5 rounded bg-amber-50 px-2.5 dark:bg-amber-950/30' : ''}">
              <span class="text-xs text-gray-500 dark:text-gray-400">${titleCase(escapeHtml(key))}</span>
              <span class="max-w-[60%] break-words text-right font-medium">${primitive(value)}</span>
            </div>`;
          })
          .join('');
      }

      function panel(label, content) {
        return `<article class="overflow-hidden rounded-lg border border-gray-200 dark:border-gray-700">
          <header class="border-b border-gray-200 bg-gray-50 px-3.5 py-2 text-xs font-medium uppercase tracking-wide text-gray-500 dark:border-gray-700 dark:bg-gray-800/50 dark:text-gray-400">${label}</header>
          <div class="overflow-x-auto bg-white ${state.mode === 'card' ? 'p-3' : ''} dark:bg-gray-900">${content}</div>
        </article>`;
      }

      function setError(element, message) {
        element.textContent = message;
        element.classList.toggle('hidden', !message);
      }

      function setShareError(message) {
        els.shareError.textContent = message;
        els.shareError.classList.toggle('hidden', !message);
      }

      function setShareUrl(url) {
        els.shareUrl.innerHTML = url
          ? `Share link: <a href="${url}" class="text-blue-600 underline dark:text-blue-300" target="_blank" rel="noreferrer">${url}</a>`
          : '';
        els.shareUrl.classList.toggle('hidden', !url);
      }

      function getCurrentShareId() {
        return new URL(window.location.href).searchParams.get('shareId');
      }

      function updateModeButtons() {
        const active = 'bg-white dark:bg-gray-700 shadow-sm font-medium';
        const inactive = 'text-gray-500 dark:text-gray-400';
        els.diffMode.className = `rounded-md px-3.5 py-1.5 text-sm transition-colors ${state.mode === 'diff' ? active : inactive}`;
        els.cardMode.className = `rounded-md px-3.5 py-1.5 text-sm transition-colors ${state.mode === 'card' ? active : inactive}`;
      }

      function updateThemeIcon() {
        const isDark = document.documentElement.classList.contains('dark');
        els.themeIcon.innerHTML = isDark
          ? '<svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="4"></circle><path stroke-linecap="round" d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41"></path></svg>'
          : '<svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79Z"></path></svg>';
      }

      function setComparedData(dataA, dataB) {
        state.dataA = dataA;
        state.dataB = dataB;
        const expanded = new Set();
        collectChangedPaths(dataA, dataB, 'root', expanded);
        state.expanded = expanded;
        const allPaths = new Set();
        collectAllPaths(dataA, dataB, 'root', allPaths);
        collectAllPaths(dataB, dataA, 'root', allPaths);
        state.allPaths = [...allPaths];
        render();
      }

      function render() {
        const hasOutput = state.dataA !== null && state.dataB !== null;
        const currentId = getCurrentShareId();
        const showSaveButton = hasOutput && currentInputsValid();
        const saveLabel = currentId ? 'Save' : 'Share';

        els.clear.classList.toggle('hidden', !hasOutput);
        els.share.classList.toggle('hidden', !showSaveButton);
        els.share.textContent = saveLabel;
        els.newSession.classList.toggle('hidden', !currentId);
        els.summary.classList.toggle('hidden', !hasOutput);
        els.summary.classList.toggle('flex', hasOutput);
        updateModeButtons();

        if (!hasOutput) {
          els.output.innerHTML = '';
          return;
        }

        const totalChanges = countChanges(state.dataA, state.dataB);
        els.changeBadge.textContent = totalChanges > 0
          ? `${totalChanges} key${totalChanges === 1 ? '' : 's'} changed`
          : 'Identical';
        els.changeBadge.className = `rounded-full px-2.5 py-1 text-xs font-medium ${totalChanges > 0 ? 'bg-amber-100 text-amber-800 dark:bg-amber-900 dark:text-amber-200' : 'bg-green-100 text-green-800 dark:bg-green-900 dark:text-green-200'}`;

        const left = state.mode === 'diff'
          ? diffRows(state.dataA, state.dataB, 0, 'a', 'root')
          : cardView(state.dataA, state.dataB, 0, 'root');
        const right = state.mode === 'diff'
          ? diffRows(state.dataB, state.dataA, 0, 'b', 'root')
          : cardView(state.dataB, state.dataA, 0, 'root');
        const labels = state.mode === 'diff' ? ['A', 'B'] : ['A - formatted', 'B - formatted'];
        els.output.innerHTML = `<div class="grid grid-cols-1 gap-2 md:grid-cols-2">${panel(labels[0], left)}${panel(labels[1], right)}</div>`;
      }

      function parseCurrentInputs() {
        setError(els.errA, '');
        setError(els.errB, '');
        setShareError('');

        if (!els.jsonA.value.trim() || !els.jsonB.value.trim()) {
          if (!els.jsonA.value.trim()) setError(els.errA, 'Paste a JSON object to compare');
          if (!els.jsonB.value.trim()) setError(els.errB, 'Paste a JSON object to compare');
          return null;
        }

        let dataA;
        let dataB;
        try {
          dataA = JSON.parse(els.jsonA.value);
        } catch (error) {
          setError(els.errA, `Invalid JSON: ${error.message}`);
          return null;
        }
        try {
          dataB = JSON.parse(els.jsonB.value);
        } catch (error) {
          setError(els.errB, `Invalid JSON: ${error.message}`);
          return null;
        }
        return { dataA, dataB };
      }

      function currentInputsValid() {
        if (!els.jsonA.value.trim() || !els.jsonB.value.trim()) return false;
        try {
          JSON.parse(els.jsonA.value);
          JSON.parse(els.jsonB.value);
          return true;
        } catch {
          return false;
        }
      }

      function runCompare() {
        setShareUrl('');
        const parsed = parseCurrentInputs();
        if (!parsed) return;
        setComparedData(parsed.dataA, parsed.dataB);
      }

      function clearAll() {
        els.jsonA.value = '';
        els.jsonB.value = '';
        setError(els.errA, '');
        setError(els.errB, '');
        setShareError('');
        setShareUrl('');
        state.dataA = null;
        state.dataB = null;
        state.expanded = new Set();
        state.allPaths = [];
        render();
      }

      function createNewSession() {
        const newUrl = window.location.pathname;
        window.history.replaceState(null, '', newUrl);
        clearAll();
      }

      async function loadSharedComparison() {
        const id = getCurrentShareId();
        if (!id) return;
        els.share.disabled = true;
        setShareError('');
        try {
          const response = await fetch(`${API_BASE}/${id}`);
          if (!response.ok) throw new Error(`Could not load shared comparison (${response.status})`);
          const data = await response.json();
          els.jsonA.value = JSON.stringify(data.json1, null, 2);
          els.jsonB.value = JSON.stringify(data.json2, null, 2);
          setComparedData(data.json1, data.json2);
          setShareUrl(window.location.href);
        } catch (error) {
          setShareError(error.message || 'Failed to load shared comparison.');
        } finally {
          els.share.disabled = false;
        }
      }

      async function shareComparison() {
        const parsed = parseCurrentInputs();
        if (!parsed) return;

        els.share.disabled = true;
        els.share.textContent = 'Saving...';
        try {
          setComparedData(parsed.dataA, parsed.dataB);
          const currentShareId = getCurrentShareId();
          const endpoint = currentShareId ? `${API_BASE}/${currentShareId}` : API_BASE;
          const response = await fetch(endpoint, {
            method: currentShareId ? 'PUT' : 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ json1: parsed.dataA, json2: parsed.dataB, comparison_result: null }),
          });
          if (!response.ok) {
            const action = currentShareId ? 'update' : 'share';
            throw new Error(`Failed to ${action} comparison (${response.status})`);
          }
          const data = await response.json();
          const shareLink = `${window.location.origin}${window.location.pathname}?shareId=${data.id}`;
          setShareUrl(shareLink);
          window.history.replaceState(null, '', shareLink);
        } catch (error) {
          setShareError(error.message || 'Unable to create share link.');
        } finally {
          els.share.disabled = false;
          els.share.textContent = 'Save';
        }
      }

      els.diffMode.addEventListener('click', () => {
        state.mode = 'diff';
        render();
      });
      els.cardMode.addEventListener('click', () => {
        state.mode = 'card';
        render();
      });
      els.themeToggle.addEventListener('click', () => {
        const nextIsDark = !document.documentElement.classList.contains('dark');
        document.documentElement.classList.toggle('dark', nextIsDark);
        localStorage.setItem('theme', nextIsDark ? 'dark' : 'light');
        updateThemeIcon();
      });
      els.loadSample.addEventListener('click', () => {
        els.jsonA.value = JSON.stringify(SAMPLE_A, null, 2);
        els.jsonB.value = JSON.stringify(SAMPLE_B, null, 2);
        setError(els.errA, '');
        setError(els.errB, '');
        setComparedData(SAMPLE_A, SAMPLE_B);
      });
      els.compare.addEventListener('click', runCompare);
      els.jsonA.addEventListener('input', render);
      els.jsonB.addEventListener('input', render);
      els.swap.addEventListener('click', () => {
        const rawA = els.jsonA.value;
        els.jsonA.value = els.jsonB.value;
        els.jsonB.value = rawA;
        if (state.dataA || state.dataB) setComparedData(state.dataB, state.dataA);
      });
      els.clear.addEventListener('click', clearAll);
      els.share.addEventListener('click', shareComparison);
      els.newSession.addEventListener('click', createNewSession);
      els.expandAll.addEventListener('click', () => {
        state.expanded = new Set(state.allPaths);
        render();
      });
      els.collapseAll.addEventListener('click', () => {
        state.expanded = new Set();
        render();
      });
      els.output.addEventListener('click', (event) => {
        const button = event.target.closest('[data-toggle]');
        if (!button) return;
        const path = button.getAttribute('data-toggle');
        if (state.expanded.has(path)) state.expanded.delete(path);
        else state.expanded.add(path);
        render();
      });

      updateThemeIcon();
      render();
      loadSharedComparison();
    </script>
  </body>
</html>
