        "@type": "FAQPage",
        "mainEntity": [
          {
            "@type": "Question",
            "name": "How do I compare two JSON files online for free?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Paste your JSON files into the left and right editors, then click Compare to see side by side JSON differences instantly without signup."
            }
