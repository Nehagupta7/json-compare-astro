---
import '../index.css';
const pageTitle = 'Terms & Conditions';
---
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/png" href="/favicon-96x96.png" sizes="96x96" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="shortcut icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <meta name="apple-mobile-web-app-title" content="json" />
    <link rel="manifest" href="/site.webmanifest" />
    <title>{pageTitle} | JSON Compare Online</title>
    <meta name="description" content="Review the Terms & Conditions for JSON Compare Online, including usage rules for our free JSON comparison tool." />
    <meta name="keywords" content="json compare, json compare online, compare json, compare two json files, json diff, json comparison tool, compare json objects, online json compare" />
    <link rel="canonical" href="https://comparejsononline.com/terms-and-conditions" />
    <meta name="robots" content="index, follow" />
    <meta property="og:type" content="website" />
    <meta property="og:title" content="JSON Compare Online - Free JSON Diff & Compare Tool" />
    <meta property="og:description" content="Compare JSON files instantly with our free online JSON Compare tool. Find differences, validate JSON, and compare JSON objects with ease." />
    <meta property="og:url" content="https://comparejsononline.com/terms-and-conditions" />
    <meta property="og:image" content="https://comparejsononline.com/og-image.png" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="JSON Compare Online - Free JSON Diff & Compare Tool" />
    <meta name="twitter:description" content="Free online JSON comparison tool to compare JSON files and objects with highlighted differences." />
    <meta name="twitter:image" content="https://comparejsononline.com/og-image.png" />
    <script is:inline>
      (() => {
        const stored = localStorage.getItem('theme');
        const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
        if (stored === 'dark' || (!stored && prefersDark)) {
          document.documentElement.classList.add('dark');
        }
      })();
    </script>
  </head>
  <body class="bg-gray-50 text-gray-900 dark:bg-gray-950 dark:text-gray-100">
    <main class="min-h-screen mx-auto max-w-5xl px-4 py-6 sm:px-6 font-sans transition-colors duration-300">
      <a href="/" class="text-sm font-medium text-blue-600 hover:text-blue-800 dark:text-blue-400">← Back to Home</a>
      <h1 class="mt-4 text-3xl font-bold tracking-tight text-gray-900 dark:text-gray-100">Terms &amp; Conditions</h1>
      <p class="mt-4 text-gray-700 dark:text-gray-300">
        These terms govern your use of JSON Compare Online. By using our json comparison tool, you agree to these conditions and acknowledge your relationship with the service.
      </p>
      <section class="mt-8 rounded-3xl border border-gray-200 bg-white p-6 shadow-sm dark:border-gray-800 dark:bg-gray-900">
        <h2 class="text-2xl font-semibold text-gray-900 dark:text-gray-100">Use of the Service</h2>
        <p class="mt-3 text-gray-700 dark:text-gray-300">
          JSON Compare Online is provided as a free json comparison online tool for developers, analysts, and QA professionals. You may use the service for personal or professional comparisons of JSON data.
        </p>
      </section>
      <section class="mt-8 rounded-3xl border border-gray-200 bg-white p-6 shadow-sm dark:border-gray-800 dark:bg-gray-900">
        <h2 class="text-2xl font-semibold text-gray-900 dark:text-gray-100">Limitations</h2>
        <p class="mt-3 text-gray-700 dark:text-gray-300">
          While we strive for accuracy, JSON Compare Online is provided without warranty. Always verify critical comparisons and use this tool as a convenient json diff checker rather than a substitute for full validation in production systems.
        </p>
      </section>
      <section class="mt-8 rounded-3xl border border-gray-200 bg-white p-6 shadow-sm dark:border-gray-800 dark:bg-gray-900">
        <h2 class="text-2xl font-semibold text-gray-900 dark:text-gray-100">Changes to Terms</h2>
        <p class="mt-3 text-gray-700 dark:text-gray-300">
          We may update these terms from time to time. Continued use of JSON Compare Online after changes means you accept the revised conditions.
        </p>
      </section>
    </main>
  </body>
</html>
